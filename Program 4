import pandas as pd 
import numpy as np 
from sklearn.cluster import KMeans 
from sklearn.preprocessing import StandardScaler 
df = pd.read_csv("py4.csv") 
X = df[["Amount", "Trans_Freq", "Account_Age"]] 
scaler = StandardScaler() 
X_scaled = scaler.fit_transform(X) 
k = KMeans(n_clusters=3, random_state=0, n_init=10) 
df["cluster"] = k.fit_predict(X_scaled) 
df["distance"] = [ 
    np.linalg.norm(x - k.cluster_centers_[c]) 
    for x, c in zip(X_scaled, df["cluster"]) 
] 
threshold = np.percentile(df["distance"], 95) 
df["suspicious"] = df["distance"] > threshold 
df[df["suspicious"]].to_csv("Suspicious_Txns.csv", index=False)
cluster_summary = df.groupby("cluster").agg( 
    transactions=("Transaction_ID", "count"), 
    suspicious=("suspicious", "sum") 
) 
cluster_summary.to_markdown("cluster_report.md") 
df.to_csv("Clustered_Transactions.csv", index=False) 
 
print("Clustering completed successfully.") 
